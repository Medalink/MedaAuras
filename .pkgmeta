package-as: MedaAuras

externals:
  Libs/MedaUI: https://github.com/Medalink/MedaUI
  Libs/LibSerialize: https://github.com/rossnichols/LibSerialize
  Libs/LibDeflate: https://github.com/SafeteeWoW/LibDeflate

ignore:
  - .git
  - .gitattributes
  - .github
  - .vscode
  - docs
  - scripts
  - .gitignore
  - .luacheckrc
  - .luarc.json
  - README.md
  - LICENSE
  - lsp-stub-gaps.json
  - lsp-stub-gaps.md
  - .pkgmeta
